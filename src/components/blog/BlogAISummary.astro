---

---

<div
    id="summary-ai-widget"
    class="my-8 border rounded bg-white shadow hidden overflow-hidden"
>
    <div class="p-6">
        <h3 id="summary-ai-widget-title">
            Generate a TL;DR with Built-in AI APIs
        </h3>
        <button
            id="summarize-btn"
            class="px-4 py-2 bg-blue-500 text-white rounded flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
            <span
                id="summarize-btn-spinner"
                class="hidden animate-spin i-uil-spinner"></span>
            <span id="summarize-btn-label">Summarize with AI</span>
        </button>
        <div id="summary-result" class="mt-4 p-4 bg-gray-100 rounded hidden">
        </div>
    </div>
    <p
        id="download-progress-label"
        class="hidden px-6 pb-1 text-xs text-gray-400"
    >
        Be patient, I'm downloading an AI model
    </p>
    <div
        id="download-progress-bar-container"
        class="hidden h-1 bg-gray-200"
        title="Model download in progress..."
    >
        <div
            id="download-progress-bar"
            class="h-full bg-blue-500 transition-all duration-200"
            style="width: 0%"
        >
        </div>
    </div>
</div>

<div
    id="summary-ai-chrome-hint"
    class="hidden my-8 p-6 border rounded bg-white shadow"
>
    <p class="text-sm text-gray-500">
        <span class="i-logos-chrome inline-block align-middle mr-1"></span>
        Want an AI-generated TL;DR? Open this page in <a
            href="https://www.google.com/chrome/"
            target="_blank"
            rel="noopener"
            class="text-blue-500 underline">Google Chrome</a
        > to try the built-in AI summarization feature.
    </p>
    <p class="text-sm text-gray-500">
        Are you a coding nerd? Check out this <a
            href="https://aleromano.com/posts/built-in-browser-ai"
            target="_blank"
            class="text-blue-500 underline">blog post</a
        >;
    </p>
</div>

<script>
    import WebNNSummarizeWorker from "../../workers/webnn-summarizer.worker.ts?worker";

    function getSlotContent() {
        const slotContainer = document.querySelector("article");
        const clone = slotContainer?.cloneNode(true) as HTMLElement | null;
        clone?.querySelector("#summary-ai-widget")?.remove();
        clone?.querySelector("#summary-ai-chrome-hint")?.remove();
        const textContent = clone?.textContent ?? null;
        return { textContent, element: slotContainer };
    }

    type SummaryAPI = "built-in" | "transformers" | "none";

    function detectSummaryAPI(): SummaryAPI {
        switch (true) {
            case "Summarizer" in self:
                return "built-in";
            case typeof window !== "undefined":
                return "transformers";
            default:
                return "none";
        }
    }

    let worker: Worker | null = null;

    function getSummarizeWorker(): Worker {
        if (!worker) {
            worker = new WebNNSummarizeWorker();
        }
        return worker;
    }

    function summarizeWithWorker(
        text: string,
        onProgress: (pct: number) => void,
    ): Promise<string> {
        return new Promise((resolve, reject) => {
            const w = getSummarizeWorker();

            const onMessage = (e: MessageEvent) => {
                const { type, pct, summary, error } = e.data;
                if (type === "progress") {
                    onProgress(pct);
                } else if (type === "result") {
                    w.removeEventListener("message", onMessage);
                    resolve(summary);
                } else if (type === "error") {
                    w.removeEventListener("message", onMessage);
                    reject(new Error(error));
                }
            };

            w.addEventListener("message", onMessage);
            w.postMessage({ text });
        });
    }

    function initSummaryWidget() {
        const widget = document.getElementById("summary-ai-widget");
        const hint = document.getElementById("summary-ai-chrome-hint");
        const widgetTitle = document.getElementById("summary-ai-widget-title");
        const btnLabel = document.getElementById("summarize-btn-label");

        const api = detectSummaryAPI();

        if (api === "built-in") {
            widget?.classList.remove("hidden");
        } else if (api === "transformers") {
            widget?.classList.remove("hidden");
            const backendLabel =
                "ml" in navigator ? "WebNN" : "Transformers.js";
            if (widgetTitle)
                widgetTitle.textContent = `Generate a TL;DR with ${backendLabel}`;
            if (btnLabel)
                btnLabel.textContent = `Summarize with ${backendLabel}`;
        } else {
            hint?.classList.remove("hidden");
        }

        const btn = document.getElementById(
            "summarize-btn",
        ) as HTMLButtonElement | null;
        const spinner = document.getElementById("summarize-btn-spinner");

        function setLoading(loading: boolean) {
            if (!btn || !spinner) return;
            btn.disabled = loading;
            spinner.classList.toggle("hidden", !loading);
        }

        const progressContainer = document.getElementById(
            "download-progress-bar-container",
        );
        const progressBar = document.getElementById("download-progress-bar");
        const progressLabel = document.getElementById(
            "download-progress-label",
        );

        function showProgress(pct: number) {
            if (progressContainer && progressBar) {
                progressContainer.classList.remove("hidden");
                progressLabel?.classList.remove("hidden");
                progressBar.style.width = `${pct}%`;
            }
        }

        function hideProgress() {
            progressContainer?.classList.add("hidden");
            progressLabel?.classList.add("hidden");
            if (progressBar) progressBar.style.width = "0%";
        }

        btn?.addEventListener("click", async () => {
            setLoading(true);

            const summaryResultElement =
                document.getElementById("summary-result");

            try {
                if (api === "built-in") {
                    const options = {
                        type: "tldr",
                        length: "long",
                        format: "plain-text",
                        outputLanguage: "en",
                    } satisfies SummarizerCreateCoreOptions;

                    const available = await Summarizer.availability(options);

                    if (available === "unavailable") {
                        console.warn(
                            "Summarizer API is unavailable in this environment.",
                        );
                        setLoading(false);
                        return;
                    }

                    console.log("Summarizer available:", available);

                    const summarizer = await Summarizer.create({
                        ...options,
                        monitor(m) {
                            m.addEventListener("downloadprogress", (e) => {
                                const pct = Math.round(e.loaded * 100);
                                console.log(`Downloaded ${pct}%`);
                                showProgress(pct);
                            });
                        },
                    });

                    hideProgress();

                    const content = getSlotContent();

                    if (!content.textContent) {
                        console.warn("No text content found to summarize.");
                        setLoading(false);
                        return;
                    }

                    const summary = summarizer.summarizeStreaming(
                        content.textContent,
                        {
                            context:
                                "This article is intended for software developers.",
                        },
                    );

                    if (summaryResultElement) {
                        summaryResultElement.textContent = "";

                        for await (const chunk of summary) {
                            if (!summaryResultElement.textContent) {
                                summaryResultElement.classList.remove("hidden");
                            }
                            summaryResultElement.append(chunk);
                        }
                    }
                } else if (api === "transformers") {
                    const content = getSlotContent();

                    if (!content.textContent) {
                        console.warn("No text content found to summarize.");
                        setLoading(false);
                        return;
                    }

                    const summaryText = await summarizeWithWorker(
                        content.textContent,
                        showProgress,
                    );

                    hideProgress();

                    if (summaryResultElement) {
                        summaryResultElement.textContent = summaryText;
                        summaryResultElement.classList.remove("hidden");
                    }
                }
            } catch (err) {
                console.error("Summarization failed:", err);
                hideProgress();
            }

            setLoading(false);
        });
    }

    document.addEventListener("astro:page-load", initSummaryWidget);
</script>
