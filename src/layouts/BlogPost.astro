---
import BlogContent from "@components/blog/BlogContent.astro";
import BlogSideBar from "@components/blog/BlogSideBar.astro";
import RecentBlogPosts from "@components/generic/RecentBlogPosts.astro";
import Layout from "./Default.astro";

const ogImage = new URL(`/v1/generate/og/${Astro.params.slug}.png`, Astro.url);

interface Props {
  author: string;
  pubDate: Date;
  headings: unknown;
  description: string;
  title: string;
  imgUrl?: { src: string };
}

const { author, pubDate, description, title, headings, imgUrl } = Astro.props;
---

<Layout
  title={title as string}
  description={description as string}
  ogImage={ogImage}
>
  <main class="p-6 lg:grid lg:grid-cols-3 flex justify-center">
    <BlogSideBar headings={headings as any[]} />
    <BlogContent
      {author}
      {pubDate}
      {title}
      {description}
      coverImage={imgUrl?.src}
    >
      <slot />
    </BlogContent>
  </main>
  <section class="p-6">
    <RecentBlogPosts count={6} />
  </section>
</Layout>

<script>
  function getSlotContent() {
    const slotContainer = document.querySelector("article");

    // Ottieni HTML
    const htmlContent = slotContainer?.innerHTML;

    // Ottieni solo testo
    const textContent = slotContainer?.textContent;

    // Oppure l'intero elemento
    const element = slotContainer;

    return { htmlContent, textContent, element };
  }

  // Esempio d'uso
  document.addEventListener("DOMContentLoaded", async () => {
    const content = getSlotContent();
    if ("Summarizer" in self) {
      const summarizer = await Summarizer.create({
        type: "tldr",
        length: "medium",
        monitor(m) {
          m.addEventListener("downloadprogress", (e) => {
            console.log(`Downloaded ${e.loaded * 100}%`);
          });
        },
      });

      const summary = await summarizer.summarize(content.textContent);
      console.log("Summary:", summary);
    }
    console.log("Contenuto dello slot:", content);

    // Fai qualcosa con il contenuto...
  });
</script>
